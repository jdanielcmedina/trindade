# Pastas de armazenamento
/storage/cache/*
/storage/logs/*
/storage/uploads/*

# Manter as pastas vazias
!storage/cache/.gitkeep
!storage/logs/.gitkeep
!storage/uploads/.gitkeep

# Arquivos de configuração
.env
.env.*
!.env.example
config.local.php

# Dependências
/vendor/
/node_modules/

# IDEs e editores
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Sistema operacional
.DS_Store
Thumbs.db
*.log

# Adicionais
/storage/*.key
composer.lock
package-lock.json 